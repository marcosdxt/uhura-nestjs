{
  "name": "@modulocker/uhura-nestjs",
  "version": "0.1.0",
  "description": "SDK NestJS do Uhura message bus (decorators contract-first sobre RabbitMQ + PostgreSQL)",
  "publishConfig": {
    "registry": "https://verdaccio.modulocker.app.br"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/marcosdxt/uhura-nestjs"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "release": "bash scripts/publish.sh"
  },
  "peerDependencies": {
    "@nestjs/common": "^10 || ^11",
    "@nestjs/core": "^10 || ^11",
    "reflect-metadata": "^0.2",
    "rxjs": "^7"
  },
  "dependencies": {
    "amqplib": "^0.10.4",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11",
    "@nestjs/core": "^11",
    "@types/amqplib": "^0.10.5",
    "@types/node": "^20",
    "@types/pg": "^8.11.0",
    "reflect-metadata": "^0.2",
    "rxjs": "^7",
    "typescript": "^5.4"
  }
}
